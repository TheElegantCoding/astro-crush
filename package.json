{
  "name": "astro-crush",
  "description": "📦️ The high-performance asset minification engine for Astro. Crush CSS, HTML, and JS to achieve peak loading speeds.",
  "author": "Luis Monsalve",
  "version": "0.0.0",
  "homepage": "https://github.com/TheElegantCoding/astro-crush#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheElegantCoding/astro-crush.git"
  },
  "keywords": [
    "typescript",
    "github",
    "git",
    "clean-code",
    "performance",
    "minification",
    "css",
    "html",
    "js",
    "astro",
    "web-development"
  ],
  "bugs": {
    "url": "https://github.com/TheElegantCoding/astro-crush/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["./dist"],
  "engines": {
    "node": ">=22.17.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "postinstall": "bunx gitlys init",
    "dev": "bunx tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --fix",
    "release": "bun run build && bunx gitlys release"
  },
  "dependencies": {
    "astro": "6.3.1",
    "fonteditor-core": "2.6.3",
    "html-minifier-terser": "7.2.0",
    "lightningcss": "1.32.0",
    "logginlys": "4.0.2",
    "node-html-parser": "7.1.0",
    "sharp": "0.34.5",
    "terser": "5.47.1"
  },
  "devDependencies": {
    "@types/html-minifier-terser": "7.0.2",
    "@types/node": "25.6.2",
    "eslint-config-universal-code": "^1.0.19",
    "gitlys": "^2.1.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
